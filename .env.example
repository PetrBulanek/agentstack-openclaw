# Required: Your OpenRouter API key
OPENROUTER_API_KEY=sk-or-...

# Optional: Override the model (full provider/model string, passed to OpenClaw config)
OPENCLAW_MODEL=openrouter/arcee-ai/trinity-large-preview:free

# Optional: Override the OpenClaw CLI version installed into the image at build time
OPENCLAW_VERSION=latest

# Optional: Max seconds to wait for a single OpenClaw CLI call before failing
OPENCLAW_AGENT_TIMEOUT=90
